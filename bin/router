#!/usr/bin/env bash
# router CLI wrapper.
#
# 默认行为：永远用 tsx 跑 src/index.ts（dev 安全，改源码立即生效）
# 想跑编译版：ROUTER_USE_DIST=1 router ...  （前提你 npm run build 过）
#
# 安装：ln -sf "$(pwd)/bin/router" /usr/local/bin/router
set -euo pipefail

# 解析 $0 经过的 symlink
SOURCE="${BASH_SOURCE[0]:-$0}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in
    /*) ;;
     *) SOURCE="$DIR/$SOURCE" ;;
  esac
done
BIN_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
REPO_DIR="$(cd -P "$BIN_DIR/.." >/dev/null 2>&1 && pwd)"

if [ ! -f "$REPO_DIR/src/index.ts" ]; then
  echo "router: cannot find src/index.ts in $REPO_DIR" >&2
  exit 3
fi

# 显式 opt-in 跑 dist；默认永远走 tsx，避免 stale dist 坑
if [ "${ROUTER_USE_DIST:-0}" = "1" ] && [ -f "$REPO_DIR/dist/index.js" ]; then
  exec node "$REPO_DIR/dist/index.js" "$@"
fi

exec npx --prefix "$REPO_DIR" tsx "$REPO_DIR/src/index.ts" "$@"
